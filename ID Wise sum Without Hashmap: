import java.util.Scanner;

public class IDWiseSumNoHashMap {

    public static void main(String[] args) {

        // Sample data: {productName, id, amount}
        String[][] data = {
            {"Apple",  "101", "500"},
            {"Mango",  "102", "300"},
            {"Apple",  "103", "200"},
            {"Banana", "101", "150"},
            {"Mango",  "104", "400"},
            {"Banana", "102", "250"}
        };

        // Unique IDs track karne ke liye array
        String[] ids = new String[data.length];
        int count = 0;

        // Step 1: Unique IDs nikalo
        for (String[] row : data) {
            String id = row[1];
            boolean found = false;

            for (int i = 0; i < count; i++) {
                if (ids[i].equals(id)) {
                    found = true;
                    break;
                }
            }

            if (!found) {
                ids[count++] = id;
            }
        }

        // Step 2: Har ID ka sum nikalo
        System.out.println("=== ID-wise Sum (Bina HashMap) ===");
        System.out.printf("%-10s %s%n", "ID", "Total Amount");
        System.out.println("----------------------");

        for (int i = 0; i < count; i++) {
            int total = 0;

            for (String[] row : data) {
                if (row[1].equals(ids[i])) {
                    total += Integer.parseInt(row[2]);
                }
            }

            System.out.printf("%-10s %d%n", ids[i], total);
        }
    }
}

